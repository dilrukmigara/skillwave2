# SkillWave Academy Server Environment Variables
# Copy this file to '.env' and fill in the values.

# Port for the express server to listen on
PORT=5050

# MongoDB URI connection string.
# Replace with your connection string from MongoDB Atlas.
# If left blank, the server will automatically fall back to the local SQLite database.
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/skillwave?retryWrites=true&w=majority
